{
  "expo": {
    "name": "Avolo",
    "slug": "avolo",
    "version": "1.0.0",
    "scheme": "avolo",
    "web": {
      "favicon": "./assets/favicon1.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router",
      "expo-build-properties"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash2.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.avolo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.anonymous.avolo"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "da05a2d9-8b9f-4785-b4ed-3d7fb708d24c"
      }
    }
  }
}
